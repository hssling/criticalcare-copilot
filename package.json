{
  "name": "criticalcare-copilot-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo root for criticalcare-copilot (frontend + Netlify Functions).",
  "workspaces": [
    "app/frontend",
    "app/functions"
  ],
  "scripts": {
    "dev": "npm --workspace app/frontend run dev",
    "build": "npm --workspace app/frontend run build",
    "lint": "npm --workspace app/frontend run lint"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
