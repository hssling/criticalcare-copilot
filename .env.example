# ============================================================================
# criticalcare-copilot environment variables (EXAMPLE - placeholders only)
# Copy to .env and fill in. NEVER commit real secrets.
# Netlify: set these in Netlify UI -> Site settings -> Environment variables.
# Do NOT place runtime secrets in netlify.toml.
# ============================================================================

# --- Hugging Face Inference Endpoint ---
HF_ENDPOINT_URL=https://<your-endpoint>.endpoints.huggingface.cloud
HF_API_TOKEN=hf_xxx_replace_me
HF_MODEL_REVISION=main

# --- HF Hub (for publishing) ---
HF_HUB_TOKEN=hf_xxx_replace_me
HF_ORG=your-org-or-user
HF_MODEL_REPO=criticalcare-copilot-gemma4-e4b

# --- Data paths (local / Kaggle) ---
MIMIC_IV_ROOT=/path/to/mimic-iv
MIMIC_IV_NOTE_ROOT=/path/to/mimic-iv-note
EICU_ROOT=/path/to/eicu
N2C2_ADE_ROOT=/path/to/n2c2-ade

# --- RAG / vector store ---
VECTOR_STORE_PATH=./data/processed/faiss_index
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Audit logging ---
AUDIT_LOG_PATH=./data/processed/audit.log

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173

# --- Frontend (public, safe to expose) ---
VITE_FUNCTIONS_BASE=/.netlify/functions

# --- RAG service (called by retrieve_context Netlify function) ---
RAG_SERVICE_URL=https://<your-rag-service>/retrieve

# --- Safety toggles ---
ENABLE_MODEL_CALL=true
ENABLE_RAG=true
SAFETY_STRICT_MODE=true
